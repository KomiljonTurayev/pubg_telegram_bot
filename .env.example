# ── Telegram Bot ──────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# ── To'lov (Click yoki Payme) ──────────────────────────────
PAYMENT_TOKEN=your_payment_provider_token_here

# ── PostgreSQL (lokal Docker uchun) ───────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Render.com uchun yuqoridagilar o'rniga shu bitta yetarli ──
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── FFmpeg ────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg

# ── Bepul tashqi API kalitlar ─────────────────────────────
# YouTube Data API v3: console.cloud.google.com → 10,000 request/kun bepul
YOUTUBE_API_KEY=

# OMDB (film ma'lumotlari): omdbapi.com → 1,000 request/kun bepul
OMDB_API_KEY=

# Deezer: auth shart emas, avtomatik ishlaydi
