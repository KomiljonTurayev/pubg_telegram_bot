# ── Telegram Bot ──────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# ── To'lov (Click yoki Payme) ──────────────────────────────
PAYMENT_TOKEN=your_payment_provider_token_here

# ── PostgreSQL (lokal Docker uchun) ───────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Render.com uchun yuqoridagilar o'rniga shu bitta yetarli ──
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── FFmpeg ────────────────────────────────────────────────
# Linux / Render: ffmpeg  (Dockerfile da o'rnatiladi)
# Windows: ffmpeg (PATH da bo'lsa) yoki to'liq yo'l
FFMPEG_PATH=ffmpeg
